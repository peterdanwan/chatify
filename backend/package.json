{
  "name": "chatify-backend",
  "version": "0.0.1",
  "description": "Chatify Backend",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon ./src/server.js",
    "sdev": "nodemon -q ./src/server.js",
    "format": "prettier --write \"./src/**/*.js\"",
    "lint": "eslint --config eslint.config.js",
    "start": "node ./src/server.js"
  },
  "keywords": [],
  "author": "Peter Wan",
  "license": "ISC",
  "type": "module",
  "imports": {
    "#controllers/*": "./src/controllers/*",
    "#config/*": "./src/config/*",
    "#routes/*": "./src/routes/*",
    "#lib/*": "./src/lib/*",
    "#models/*": "./src/models/*",
    "#emails/*": "./src/emails/*",
    "#middleware/*": "./src/middleware/*"
  },
  "lint-staged": {
    "src/**/*.js": [
      "prettier --write",
      "eslint --config eslint.config.js"
    ]
  },
  "dependencies": {
    "@arcjet/inspect": "^1.0.0-beta.17",
    "@arcjet/node": "^1.0.0-beta.17",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.1",
    "pino": "^10.1.0",
    "resend": "^6.6.0",
    "stoppable": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@orangeopensource/hurl": "^7.1.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "supertest": "^7.2.2"
  }
}
