
# ============================================================
# Dockerfile.dev
# Builds frontend and serves it from the backend using nodemon
# ============================================================

# ============================================
# Stage 1: Build Frontend
# ============================================
FROM node:24.11.1-alpine AS frontend-build
WORKDIR /app/frontend

# Copy our frontend folder's package files
# We copy these first to leverage Docker's layer caching
# If the package*.json files don't change, Docker reuses the cached layer
COPY frontend/package*.json ./

# Install all our frontend's dependencies and devDependencies
# with the versions listed on the package-lock.json file
RUN npm ci

# Copy our frontend's source code to the WORKDIR (/app/frontend/)
COPY frontend/ ./

# Build the frontend (creates dist folder using the "vite" devDependency)
RUN npm run build

# ============================================
# Stage 2: Backend Dependencies
# ============================================
FROM node:24.11.1-alpine AS backend-deps
WORKDIR /app

# Copy our backend folder's package files
# Again, we copy these first to leverage Docker's layer caching
# If the package*.json files don't change, Docker reuses the cached layer
COPY backend/package*.json ./

# Install all dependencies and devDependencies with the versions pinned in our backend's package-lock.json file
RUN npm ci

# ============================================
# Stage 3: Development - Final Image
# ============================================
FROM node:24.11.1-alpine AS development

# Create non-root user for security
RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001

WORKDIR /app

# Copy the installed backend development dependencies from Stage 2 to /app/backend/node_modules
COPY --from=backend-deps --chown=nodejs:nodejs /app/node_modules ./backend/node_modules

# Copy backend source code to /app/backend/src
COPY --chown=nodejs:nodejs backend/src ./backend/src
COPY --chown=nodejs:nodejs backend/package*.json ./backend/

# Copy the built frontend to /app/frontend/dist
COPY --from=frontend-build --chown=nodejs:nodejs /app/frontend/dist ./frontend/dist

# Switch to non-root user
USER nodejs

# Change working directory to backend
WORKDIR /app/backend

# Expose the port your server listens on
EXPOSE 3000

# Health check (optional but recommended)
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"

# Start the server
CMD ["nodemon", "./src/server.js"]