{
  "name": "chatify",
  "version": "0.0.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "backend-dev": "node ./backend/src/server.js",
    "prepare": "husky",
    "lint": "eslint --config eslint.config.js",
    "format": "prettier --write \"./backend/src/**/*.js\" && prettier --write \"./backend/src/**/*.js\"",
    "build": "npm i -C backend && npm i -C frontend && npm run build -C frontend",
    "start": "npm run start -C backend"
  },
  "keywords": [],
  "author": "Peter Wan",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "express": "^5.2.1",
    "init": "^0.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4"
  },
  "lint-staged": {
    "backend/src/**/*.js": ["prettier --write", "eslint --config eslint.config.js"],
    "frontend/src/**/*.{js,html.css}": ["prettier --write", "eslint --config eslint.config.js"],
    "frontend/src/**/*.js": ["prettier --write", "eslint --config eslint.config.js"]
  }
}
